## 2. TypeScript Best Practices

### 2.1 Avoid React.FC

**❌ Don't:**

```typescript
const MyComponent: React.FC<Props> = ({ prop1 }) => {
  return <div>{prop1}</div>;
};
```

**✅ Do:**

```typescript
const MyComponent = ({ prop1 }: Props) => {
  return <div>{prop1}</div>;
};

// Or with return type annotation
const MyComponent = ({ prop1 }: Props): JSX.Element => {
  return <div>{prop1}</div>;
};
```

**Reason:** `React.FC` has implicit children prop and other issues. Explicit typing is clearer and more flexible.

### 2.2 Avoid `any` and `unknown`

**❌ Don't:**

```typescript
const processData = (data: any) => {
  return data.value; // No type safety
};

const response: any = await api.fetch();
```

**✅ Do:**

```typescript
interface ApiResponse {
  value: string;
  status: number;
}

const processData = (data: ApiResponse) => {
  return data.value; // Type safe
};

const response: ApiResponse = await api.fetch();

// If type is truly unknown, use proper type guards
const processUnknown = (data: unknown) => {
  if (typeof data === 'object' && data !== null && 'value' in data) {
    return (data as ApiResponse).value;
  }
  throw new Error('Invalid data structure');
};
```

### 2.3 Avoid Inline Type Assertions

**❌ Don't:**

```typescript
const MyComponent = () => {
  const data = useAppSelector((state) => state.data) as MyData;
  const items = response.items as Array<{ id: string; name: string }>;

  return (
    <div>
      {items.map((item) => (
        <span key={item.id}>{item.name}</span>
      ))}
    </div>
  );
};
```

**✅ Do:**

```typescript
// Define types in types.ts
interface MyData {
  id: string;
  value: number;
}

interface Item {
  id: string;
  name: string;
}

// Use proper typing in component
const MyComponent = () => {
  const data = useAppSelector((state): MyData => state.data);
  const items: Item[] = response.items;

  return (
    <div>
      {items.map((item) => (
        <span key={item.id}>{item.name}</span>
      ))}
    </div>
  );
};
```

### 2.4 Use Type Inference When Appropriate

**✅ Do:**

```typescript
// Type inference works well here
const [count, setCount] = useState(0); // inferred as number
const [isOpen, setIsOpen] = useState(false); // inferred as boolean

// Explicit typing when needed
const [user, setUser] = useState<User | null>(null);
const [items, setItems] = useState<Item[]>([]);
```

### 2.5 Proper Return Type Annotations

**✅ Do:**

```typescript
// For functions that might have complex return types
const calculateMetrics = (data: Data[]): Metrics => {
  return {
    total: data.length,
    average: data.reduce((sum, d) => sum + d.value, 0) / data.length,
  };
};

// For async functions
const fetchData = async (id: string): Promise<ApiResponse> => {
  const response = await api.fetch(id);
  return response.data;
};
```

