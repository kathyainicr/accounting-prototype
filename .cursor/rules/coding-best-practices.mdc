## 12. Code Organization

### 12.1 Keep Components Small

**✅ Guidelines:**

```typescript
// If a component exceeds ~300 lines, consider:
// 1. Extracting sub-components
// 2. Moving logic to custom hooks
// 3. Creating utility functions

// Bad: 800-line component with everything
const HugeComponent = () => {
  // Too much logic here
};

// Good: Split into focused components
const ParentComponent = () => {
  const { data, actions } = useComponentLogic();

  return (
    <Box>
      <ComponentHeader data={data} />
      <ComponentBody data={data} actions={actions} />
      <ComponentFooter actions={actions} />
    </Box>
  );
};
```

### 12.2 Extract Complex Logic

**✅ Do:**

```typescript
// Move complex logic to utils.ts
// utils.ts
export const calculatePayoutMetrics = (payouts: Payout[]): Metrics => {
  const total = payouts.reduce((sum, p) => sum + p.amount, 0);
  const pending = payouts.filter((p) => p.status === 'pending').length;
  const processed = payouts.filter((p) => p.status === 'processed').length;

  return { total, pending, processed };
};

// Component stays clean
const PayoutsComponent = () => {
  const payouts = useAppSelector((state) => state.payouts.items);
  const metrics = useMemo(() => calculatePayoutMetrics(payouts), [payouts]);

  return <MetricsDisplay metrics={metrics} />;
};
```

### 12.3 Consistent Naming

**✅ Do:**

```typescript
// Files: PascalCase for components, camelCase for utilities
ComponentName.tsx;
types.ts;
constants.ts;
utils.ts;
