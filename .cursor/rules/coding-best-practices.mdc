### 12.4 File Organization Best Practices

Organize component code into separate files for better maintainability and readability.

**❌ Don't - Everything in one file:**

```typescript
// ❌ BAD - index.tsx with everything mixed together
import React, { useState } from 'react';

const SALARY_TAX_RATE = 0.3;
const BONUS_MULTIPLIER = 1.5;

type Employee = {
  id: string;
  name: string;
  salary: number;
};

const calculateTax = (salary: number) => salary * SALARY_TAX_RATE;
const calculateBonus = (salary: number) => salary * BONUS_MULTIPLIER;

export const EmployeeDetails = ({ employeeId }: { employeeId: string }) => {
  const [employee, setEmployee] = useState<Employee | null>(null);

  const tax = employee ? calculateTax(employee.salary) : 0;
  const bonus = employee ? calculateBonus(employee.salary) : 0;

  return <div>{/* 200 lines of JSX */}</div>;
};
```

**✅ Do - Organized structure:**

```typescript
// types.ts
export type Employee = {
  id: string;
  name: string;
  salary: number;
};

export type EmployeeDetailsProps = {
  employeeId: string;
};

// constants.ts
export const SALARY_TAX_RATE = 0.3;
export const BONUS_MULTIPLIER = 1.5;

export const EMPLOYMENT_TYPES = {
  FULL_TIME: 'full_time',
  PART_TIME: 'part_time',
  CONTRACT: 'contract',
} as const;

export type EmploymentType = (typeof EMPLOYMENT_TYPES)[keyof typeof EMPLOYMENT_TYPES];

// utils.ts
import { SALARY_TAX_RATE, BONUS_MULTIPLIER } from './constants';

/**
 * Calculate tax on salary
 * @param salary - Employee salary
 * @returns Tax amount
 */
export const calculateTax = (salary: number): number => {
  return salary * SALARY_TAX_RATE;
};

/**
 * Calculate bonus on salary
 * @param salary - Employee salary
 * @returns Bonus amount
 */
export const calculateBonus = (salary: number): number => {
  return salary * BONUS_MULTIPLIER;
};

/**
 * Format amount as Indian currency
 * @param amount - Amount to format
 * @returns Formatted currency string
 */
export const formatCurrency = (amount: number): string => {
  return new Intl.NumberFormat('en-IN', {
    style: 'currency',
    currency: 'INR',
  }).format(amount);
};

// index.tsx
import { useState } from 'react';
import { Box, Text, Heading } from '@razorpay/blade/components';
import type { Employee, EmployeeDetailsProps } from './types';
import { calculateTax, calculateBonus, formatCurrency } from './utils';

export const EmployeeDetails = ({ employeeId }: EmployeeDetailsProps) => {
  const [employee, setEmployee] = useState<Employee | null>(null);

  const tax = employee ? calculateTax(employee.salary) : 0;
  const bonus = employee ? calculateBonus(employee.salary) : 0;

  return (
    <Box padding="spacing.5">
      <Heading>{employee?.name}</Heading>
      <Text>Tax: {formatCurrency(tax)}</Text>
      <Text>Bonus: {formatCurrency(bonus)}</Text>
    </Box>
  );
};
```

### 12.5 Prop Destructuring and Early Returns

**✅ Prop Destructuring:**

```typescript
// ❌ Don't access props repeatedly
const MyComponent = (props: MyComponentProps) => {
  return (
    <Box>
      <Text>{props.title}</Text>
      <Text>{props.description}</Text>
      <Button onClick={props.onSubmit}>Submit</Button>
    </Box>
  );
};

// ✅ Do destructure props in parameters
const MyComponent = ({ title, description, onSubmit }: MyComponentProps) => {
  return (
    <Box>
      <Text>{title}</Text>
      <Text>{description}</Text>
      <Button onClick={onSubmit}>Submit</Button>
    </Box>
  );
};
```

**✅ Early Returns:**

```typescript
// ❌ Don't nest conditions deeply
const UserProfile = ({ userId }: Props) => {
  const user = useAppSelector((state) => state.users[userId]);

  return (
    <Box>
      {user ? (
        <Box>
          {user.isActive ? (
            <Box>
              <Text>{user.name}</Text>
              {/* 50 more lines */}
            </Box>
          ) : (
            <Text>User is inactive</Text>
          )}
        </Box>
      ) : (
        <Text>User not found</Text>
      )}
    </Box>
  );
};

// ✅ Do use early returns
const UserProfile = ({ userId }: Props) => {
  const user = useAppSelector((state) => state.users[userId]);

  // Early return for missing data
  if (!user) {
    return <Text>User not found</Text>;
  }

  // Early return for inactive state
  if (!user.isActive) {
    return <Text>User is inactive</Text>;
  }

  // Main render logic without nesting
  return (
    <Box>
      <Text>{user.name}</Text>
      {/* Clean, readable main content */}
    </Box>
  );
};
```

