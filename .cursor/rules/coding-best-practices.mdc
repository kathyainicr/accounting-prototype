## 1. Component Structure

### 1.1 Directory Organization

Every component folder should follow this standardized structure:

```
ComponentName/
├── index.tsx           # Main component file
├── types.ts            # Type definitions and interfaces
├── constants.ts        # Constants, enums, and configuration
├── utils.ts            # Utility functions specific to this component
├── hooks.ts            # Custom hooks (if needed)
├── styles.ts           # Styled components (if using styled-components)
├── __tests__/          # Test files
│   ├── ComponentName.test.tsx
│   ├── apiHandlers.ts  # MSW handlers for API mocking
│   └── mockdata.ts     # Mock data for tests
└── components/         # Sub-components (if needed)
    └── SubComponent.tsx
```

### 1.2 Component File Template

**index.tsx:**

```typescript
import { useState, useEffect, useCallback } from 'react';
import { useNavigate } from 'modules/react-router';
import { Box, Button, Text } from '@razorpay/blade/components';
import { useAppSelector } from 'modules/storeHooks';
import { ComponentNameProps } from './types';
import { COMPONENT_CONSTANTS } from './constants';
import { helperFunction } from './utils';

export const ComponentName = ({ prop1, prop2 }: ComponentNameProps) => {
  // 1. Hooks (state, router, redux)
  const navigate = useNavigate();
  const stateValue = useAppSelector((state) => state.app.someValue);
  const [localState, setLocalState] = useState<string>('');

  // 2. Derived values and memoized calculations
  const derivedValue = useMemo(() => {
    return helperFunction(localState);
  }, [localState]);

  // 3. Event handlers and callbacks
  const handleClick = useCallback(() => {
    // Handle click
  }, []);

  // 4. Side effects
  useEffect(() => {
    // Side effect logic
  }, []);

  // 5. Render logic
  return (
    <Box>
      <Text>{derivedValue}</Text>
      <Button onClick={handleClick}>Click Me</Button>
    </Box>
  );
};

// Named export (default exports are acceptable for page-level components)
export default ComponentName;
```

**types.ts:**

```typescript
export interface ComponentNameProps {
  prop1: string;
  prop2?: number;
  onAction?: (data: ActionData) => void;
}

export interface ActionData {
  id: string;
  value: string;
}

export type ComponentVariant = 'primary' | 'secondary' | 'tertiary';
```

**constants.ts:**

```typescript
export const COMPONENT_CONSTANTS = {
  MAX_ITEMS: 10,
  DEFAULT_TIMEOUT: 3000,
} as const;

export const STATUS_TYPES = {
  PENDING: 'pending',
  APPROVED: 'approved',
  REJECTED: 'rejected',
} as const;

export type StatusType = (typeof STATUS_TYPES)[keyof typeof STATUS_TYPES];
```

**utils.ts:**

```typescript
/**
 * Formats a value according to component requirements
 * @param value - The value to format
 * @returns Formatted string
 */
export const formatValue = (value: string): string => {
  return value.trim().toLowerCase();
};

export const calculateTotal = (items: Item[]): number => {
  return items.reduce((sum, item) => sum + item.amount, 0);
};
```

