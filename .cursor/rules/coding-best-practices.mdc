## 8. Testing Requirements

### 8.1 Test File Structure

```typescript
// ComponentName.test.tsx
import { screen, waitFor } from '@testing-library/react';
import userEvent from '@testing-library/user-event';
import { renderApp } from 'modules/renderApp';
import setupTestServer from 'modules/testUtils/setupTestServer';
import ComponentName from '../index';
import { apiHandlers } from './apiHandlers';
import { mockData } from './mockdata';

describe('ComponentName', () => {
  beforeEach(() => {
    setupTestServer(apiHandlers);
  });

  afterEach(() => {
    jest.clearAllMocks();
  });

  test('should render component correctly', async () => {
    renderApp(<ComponentName />, {
      initialRoute: '/path',
      initialReduxState: mockData,
    });

    expect(await screen.findByText('Expected Text')).toBeInTheDocument();
  });

  test('should handle user interaction', async () => {
    renderApp(<ComponentName />);

    const button = screen.getByRole('button', { name: /submit/i });
    userEvent.click(button);

    await waitFor(() => {
      expect(screen.getByText('Success')).toBeInTheDocument();
    });
  });
});
```

### 8.2 Coverage Requirements

```typescript
// ✅ Maintain unit test coverage
// Run: yarn test -- --coverage
// Check: coverage/lcov-report/index.html

// Key requirements:
// 1. Test files required for new components
// 2. Coverage for critical business logic
// 3. API handlers properly mocked
// 4. User interactions tested
```

### 8.3 Test Best Practices

**✅ Do:**

```typescript
// 1. Test user behavior, not implementation
test('should display error message when form submission fails', async () => {
  // Arrange
  setupTestServer(errorHandlers);
  renderApp(<Form />);

  // Act
  userEvent.type(screen.getByLabelText(/name/i), 'John');
  userEvent.click(screen.getByRole('button', { name: /submit/i }));

  // Assert
  expect(await screen.findByText(/error occurred/i)).toBeInTheDocument();
});

// 2. Use accessible queries
// Preferred: getByRole, getByLabelText, getByText
// Avoid: getByTestId (use sparingly)

// 3. Wait for async operations
await waitFor(() => {
  expect(screen.getByText('Loaded')).toBeInTheDocument();
});

// 4. Test edge cases
test('should handle empty state', () => {
  renderApp(<List items={[]} />);
  expect(screen.getByText(/no items/i)).toBeInTheDocument();
});
```

### 8.4 Build Error Checks

**✅ Always check before committing:**

```bash
# 1. Run tests
yarn test

# 2. Check TypeScript errors
yarn tsc --noEmit

# 3. Run linter
yarn lint

# 4. Build check
yarn build
```

