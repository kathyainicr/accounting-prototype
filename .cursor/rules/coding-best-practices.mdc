## 9. Analytics Integration

### 9.1 RazorAnalytics Setup

```typescript
// Use data-analytics attributes for tracking
import { Button, Link } from '@razorpay/blade/components';

// For buttons
<Button data-analytics-name="submit-payment">
  Submit Payment
</Button>

// For links with button variant
<Link
  variant="button"
  href="/settings"
  data-analytics-name="open-settings"
>
  Settings
</Link>

// For forms
<form name="create-payout-form">
  <TextInput name="amount" label="Amount" />
  <TextInput name="contact" label="Contact" />
  <Button type="submit" data-analytics-name="submit-payout">
    Submit
  </Button>
</form>
```

### 9.2 Analytics Naming Convention

**✅ Do:**

```typescript
// Use kebab-case for analytics names
data-analytics-name="create-new-payout"
data-analytics-name="download-statement"
data-analytics-name="approve-workflow"

// Base on component context
// File: CreatePayoutModal/index.tsx
<Button data-analytics-name="create-payout-submit">Submit</Button>
<Button data-analytics-name="create-payout-cancel">Cancel</Button>
```

### 9.3 Container Components Analytics

```typescript
// Add data-analytics-name to all container components
<Accordion data-analytics-name="payout-details-accordion">
  <AccordionItem title="Payment Info">...</AccordionItem>
</Accordion>

<Modal data-analytics-name="confirm-payment-modal">
  <ModalHeader>Confirm Payment</ModalHeader>
</Modal>

<Drawer data-analytics-name="filters-drawer">
  <DrawerHeader>Filters</DrawerHeader>
</Drawer>
```

### 9.4 Analytics Testing Requirements

**CRITICAL:** When adding analytics, tests MUST verify analytics calls:

```typescript
import { spyOnRazorAnalytics } from 'modules/razorAnalytics/__tests__/razorAnalyticsTestUtils';

describe('Component with Analytics', () => {
  let analyticsMock: ReturnType<typeof spyOnRazorAnalytics>;

  beforeEach(() => {
    analyticsMock = spyOnRazorAnalytics();
  });

  afterEach(() => {
    jest.restoreAllMocks();
  });

  test('should track button click event', async () => {
    renderApp(<MyComponent />);

    userEvent.click(screen.getByRole('button', { name: /submit/i }));

    expect(analyticsMock.trackEvent).toHaveBeenCalledWith({
      eventName: 'button_clicked',
      attributes: expect.objectContaining({
        buttonName: 'submit',
      }),
    });
  });
});
```

