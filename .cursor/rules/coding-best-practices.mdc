## 7. Custom Hooks

### 7.1 Hook File Organization

```typescript
// hooks.ts or useFeatureName.ts
import { useState, useCallback } from 'react';
import { useAppSelector } from 'modules/storeHooks';

/**
 * Custom hook for managing feature state
 * @param initialValue - Initial value for the feature
 * @returns Feature state and actions
 */
export const useFeatureName = (initialValue: string) => {
  const [value, setValue] = useState(initialValue);
  const globalData = useAppSelector((state) => state.feature.data);

  const updateValue = useCallback((newValue: string) => {
    setValue(newValue);
  }, []);

  return {
    value,
    globalData,
    updateValue,
  };
};
```

### 7.2 Hook Naming Convention

```typescript
// ✅ Good hook names
useUserData();
usePayoutActions();
useFormValidation();
useQuerySearch();

// ❌ Bad hook names
getUserData(); // Not a hook
fetchUser(); // Should be useFetchUser or useUserData
hookForPayouts(); // Unclear naming
```

### 7.3 Hook Best Practices

**✅ Do:**

```typescript
// 1. Return objects for multiple values
const useAuth = () => {
  return {
    user,
    isAuthenticated,
    login,
    logout,
  };
};

// 2. Provide clear return types
interface UseAuthReturn {
  user: User | null;
  isAuthenticated: boolean;
  login: (credentials: Credentials) => Promise<void>;
  logout: () => void;
}

export const useAuth = (): UseAuthReturn => {
  // Implementation
};

// 3. Keep hooks focused and single-purpose
// Bad: useUserDataAndPayoutsAndSettings()
// Good: useUserData(), usePayouts(), useSettings()
```

